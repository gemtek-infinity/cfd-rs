# .editorconfig
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[Makefile]
indent_style = tab
tab_width = 8

[*.{json,jsonc,toml,yaml,yml}]
indent_size = 2

[Justfile]
indent_size = 2

[*.md]
trim_trailing_whitespace = false # markdown feature of semantic line breaks
