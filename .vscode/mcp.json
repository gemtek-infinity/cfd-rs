{
  "servers": {
    "cfd-rs-memory": {
      "type": "stdio",
      "env": {
        "MCP_LOG": "brief"
      },
      "command": "cargo",
      "args": [
        "run",
        "--locked",
        "--quiet",
        "--manifest-path",
        "${workspaceFolder}/tools/mcp-cfd-rs/Cargo.toml",
        "--release",
        "--features",
        "debtmap"
      ],
      "cwd": "${workspaceFolder}"
    },
    "io.github.github/github-mcp-server": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
        "ghcr.io/github/github-mcp-server:0.33.0"
      ]
    }
  },
  "inputs": [
    {
      "id": "token",
      "type": "promptString",
      "description": "",
      "password": true
    }
  ]
}
